{
	"info": {
		"_postman_id": "staffroom-backend-v1-full",
		"name": "StaffRoom API (Complete)",
		"description": "Complete Postman collection for StaffRoom Teaching Marketplace API including all features and admin endpoints.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"full_name\": \"Jane Teacher\",\n  \"email\": \"jane@staffroom.ng\",\n  \"phone\": \"08000000000\",\n  \"password\": \"password123\",\n  \"role\": \"teacher\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if(jsonData.token) { pm.environment.set(\"token\", jsonData.token); }"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"jane@staffroom.ng\",\n  \"password\": \"password123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
					}
				}
			]
		},
		{
			"name": "Jobs",
			"item": [
				{
					"name": "Browse Jobs",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/jobs?subject=Mathematics&state=Lagos",
							"host": ["{{baseUrl}}"],
							"path": ["jobs"],
							"query": [
								{ "key": "subject", "value": "Mathematics" },
								{ "key": "state", "value": "Lagos" }
							]
						}
					}
				},
				{
					"name": "Get Job by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/jobs/1", "host": ["{{baseUrl}}"], "path": ["jobs", "1"] }
					}
				},
				{
					"name": "Create Job",
					"request": {
						"auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] },
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Math Teacher\",\n  \"description\": \"Looking for a math teacher\",\n  \"role_type\": \"Mathematics Teacher\",\n  \"employment_type\": \"full-time\",\n  \"salary_range\": \"100k-150k\",\n  \"location\": \"Lagos\",\n  \"requirements\": \"BSc Mathematics\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/jobs", "host": ["{{baseUrl}}"], "path": ["jobs"] }
					}
				},
				{
					"name": "Update Job",
					"request": {
						"auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] },
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Senior Math Teacher\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/jobs/1", "host": ["{{baseUrl}}"], "path": ["jobs", "1"] }
					}
				},
				{
					"name": "Delete Job",
					"request": {
						"auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] },
						"method": "DELETE",
						"header": [],
						"url": { "raw": "{{baseUrl}}/jobs/1", "host": ["{{baseUrl}}"], "path": ["jobs", "1"] }
					}
				}
			]
		},
